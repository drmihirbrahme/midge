#!/usr/bin/env python3
"""midge — tiny engine, immense models.

Commands:
    midge chat <model_dir>          interactive chat (harmony template)
    midge run  <model_dir> -p "…"   one-shot generation
    midge convert <src> <outdir>    convert a HF checkpoint (see tools/convert.py)
    midge plan <model_dir|spec>     RAM / storage / IO math for a model

The heavy lifting happens in ./midged (C). This shell only tokenizes,
formats the chat template and speaks the engine's line protocol
(token ids in, token ids out).
"""
from __future__ import annotations
import argparse
import signal
import json
import os
import shutil
import subprocess
import sys

signal.signal(signal.SIGPIPE, signal.SIG_DFL)   # clean exit when piped to head/less
ROOT = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(ROOT, "tools"))
from harmony import Harmony  # noqa: E402


def die(msg):
    print(f"midge: {msg}", file=sys.stderr)
    sys.exit(1)


def load_tokenizer(model_dir):
    try:
        from tokenizers import Tokenizer
    except ImportError:
        die("the chat/run commands need the `tokenizers` package:\n"
            "  pip install tokenizers")
    p = os.path.join(model_dir, "tokenizer.json")
    if not os.path.exists(p):
        die(f"{p} not found — copy the checkpoint's tokenizer.json there")
    return Tokenizer.from_file(p)


def load_spec(model_dir):
    p = os.path.join(model_dir, "spec.json")
    if not os.path.exists(p):
        die(f"{p} not found — is this a converted midge model dir?")
    with open(p) as f:
        return json.load(f)


# --------------------------------------------------------------- engine
from engine_client import EngineProc, EngineError  # noqa: E402


class Engine(EngineProc):
    """CLI-flavoured wrapper: die() on errors, ROOT-relative binary."""

    def __init__(self, model_dir, ctx, temp, topp, seed, stop_ids, preload_gb):
        try:
            super().__init__(os.path.join(ROOT, "midged"), model_dir, ctx,
                             temp, topp, seed, stop_ids, preload_gb)
        except EngineError as e:
            die(str(e))

    def generate(self, ngen, stop_ids, on_token):
        try:
            return super().generate(ngen, stop_ids, on_token)
        except EngineError as e:
            die(str(e))


# ------------------------------------------------------------- commands
def add_engine_args(ap):
    ap.add_argument("--ctx", type=int, default=8192)
    ap.add_argument("--temp", type=float, default=0.7)
    ap.add_argument("--topp", type=float, default=0.9)
    ap.add_argument("--seed", type=int, default=42)
    ap.add_argument("--ngen", type=int, default=2048, help="max tokens per reply")
    ap.add_argument("--preload-gb", type=float, default=0,
                    help="warm this much of the hottest experts into page cache")
    ap.add_argument("--no-analysis", action="store_true",
                    help="hide the model's analysis channel")
    ap.add_argument("--system", default="You are a helpful assistant.")
    ap.add_argument("--reasoning", default="low",
                    choices=["low", "medium", "high"])


def cmd_chat(args):
    spec = load_spec(args.model_dir)
    tok = load_tokenizer(args.model_dir)
    h = Harmony(tok, spec)
    eng = Engine(args.model_dir, args.ctx, args.temp, args.topp, args.seed,
                 h.stop_ids, args.preload_gb)
    system = f"{args.system}\nReasoning: {args.reasoning}"
    eng.prefill(h.render([{"role": "system", "content": system}],
                         add_generation_prefix=False))
    print("(chat ready — Ctrl-D or /quit to exit)")
    try:
        while True:
            try:
                user = input("\n> ").strip()
            except EOFError:
                break
            if not user:
                continue
            if user in ("/quit", "/exit"):
                break
            eng.prefill(h.render([{"role": "user", "content": user}]))
            on_token, finish = h.stream(show_analysis=not args.no_analysis)
            eng.generate(args.ngen, h.stop_ids, on_token)
            finish()
            print()
    finally:
        eng.close()


def cmd_run(args):
    spec = load_spec(args.model_dir)
    tok = load_tokenizer(args.model_dir)
    h = Harmony(tok, spec)
    eng = Engine(args.model_dir, args.ctx, args.temp, args.topp, args.seed,
                 h.stop_ids, args.preload_gb)
    system = f"{args.system}\nReasoning: {args.reasoning}"
    msgs = [{"role": "system", "content": system},
            {"role": "user", "content": args.prompt}]
    eng.prefill(h.render(msgs))
    on_token, finish = h.stream(show_analysis=not args.no_analysis)
    eng.generate(args.ngen, h.stop_ids, on_token)
    finish()
    print()
    eng.close()


def cmd_convert(args, extra):
    os.execv(sys.executable,
             [sys.executable, os.path.join(ROOT, "tools/convert.py")] + extra)


def cmd_plan(args):
    sys.path.insert(0, os.path.join(ROOT, "tools"))
    import midgepack as wp
    p = args.model_dir
    spec_path = p if p.endswith(".json") else os.path.join(p, "spec.json")
    with open(spec_path) as f:
        spec = json.load(f)
    s = spec
    hid, ffn = s["hidden"], s["moe"]["ffn"]
    E, K, L = s["moe"]["experts"], s["moe"]["top_k"], s["n_layers"]
    nh, nkv, hd, V = s["n_heads"], s["n_kv_heads"], s["head_dim"], s["vocab"]

    def gb(x):
        return x / (1 << 30)

    lay = wp.ExpertLayout(args.experts, hid, ffn, E, L)
    # dense (matrices + f32 vectors), rough
    mats = 2 * V * hid + L * (2 * nh * hd * hid + 2 * nkv * hd * hid) + L * E * hid
    dense = mats * (4.0 if args.dense == "f32" else 1.03125)  # q8r ≈ 1 B + scales
    kv_bytes = 0
    win = s["attn"].get("sliding_window", 0)
    for lt in s["attn"]["layer_types"]:
        cap = win if ("sliding" in lt and 0 < win < args.ctx) else args.ctx
        kv_bytes += 2 * cap * nkv * hd * 2
    per_tok = L * K * lay.expert_stride

    print(f"model: {L} layers · {E} experts (top-{K}) · hidden {hid} · vocab {V}")
    print(f"storage  experts.midge ({args.experts}): {gb(lay.total):7.1f} GiB")
    print(f"         dense.midge   ({args.dense}):   {gb(dense):7.1f} GiB")
    print(f"resident dense mmap (hot):     ~{gb(dense):6.1f} GiB")
    print(f"         KV cache @ ctx {args.ctx}: {gb(kv_bytes):7.2f} GiB")
    print(f"IO       cold expert reads:    {per_tok / (1 << 20):7.1f} MiB/token")
    print(f"         one expert ({args.experts}):    {lay.expert_stride / (1 << 20):7.1f} MiB")
    print()
    print("rules of thumb: warm tok/s ≈ what your CPU can matvec through")
    print(f"{gb(dense + K * L * lay.expert_stride):.1f} GiB/token; cold tok/s ≈ disk_MBps / "
          f"{per_tok / (1 << 20):.0f}.")


def main():
    ap = argparse.ArgumentParser(prog="midge", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    c = sub.add_parser("chat", help="interactive chat")
    c.add_argument("model_dir")
    add_engine_args(c)

    r = sub.add_parser("run", help="one-shot generation")
    r.add_argument("model_dir")
    r.add_argument("-p", "--prompt", required=True)
    add_engine_args(r)

    v = sub.add_parser("convert", help="convert a HF checkpoint",
                       add_help=False)

    sv = sub.add_parser("serve", help="OpenAI-compatible local API server",
                        add_help=False)

    u = sub.add_parser("ui", help="web interface: download, convert, chat",
                       add_help=False)

    pl = sub.add_parser("plan", help="RAM/storage/IO math")
    pl.add_argument("model_dir", help="model dir or spec.json")
    pl.add_argument("--experts", default="mxfp4",
                    choices=["mxfp4", "q4g32", "q8r", "f32"])
    pl.add_argument("--dense", default="q8r", choices=["q8r", "f32"])
    pl.add_argument("--ctx", type=int, default=8192)

    if len(sys.argv) > 1 and sys.argv[1] == "convert":
        return cmd_convert(None, sys.argv[2:])
    if len(sys.argv) > 1 and sys.argv[1] == "serve":
        from serve import main as serve_main
        return serve_main(sys.argv[2:])
    if len(sys.argv) > 1 and sys.argv[1] == "ui":
        from ui import main as ui_main
        return ui_main(sys.argv[2:])
    args = ap.parse_args()
    if args.cmd == "chat":
        cmd_chat(args)
    elif args.cmd == "run":
        cmd_run(args)
    elif args.cmd == "plan":
        cmd_plan(args)


if __name__ == "__main__":
    main()
